5;1845\",\r\n            \"attributeKey\": \"ATTRIBUTEKEY_WHITELIST\",\r\n            \"menuItemId\": 4547\r\n        }, {\r\n            \"menuAttributeId\": 25347,\r\n            \"menuAttributeValue\": \"B;P;T;K\",\r\n            \"attributeKey\": \"ATTRIBUTEKEY_BRANCHTYPE\",\r\n            \"menuItemId\": 4547\r\n        }, {\r\n            \"menuAttributeId\": 25348,\r\n            \"menuAttributeValue\": \"ürün kodu alanı\",\r\n            \"attributeKey\": \"ATTRIBUTEKEY_PRODUCTCODE\",\r\n            \"menuItemId\": 4547\r\n        }, {\r\n            \"menuAttributeId\": 25349,\r\n            \"menuAttributeValue\": \"iş birimi alanı\",\r\n            \"attributeKey\": \"ATTRIBUTEKEY_REGULATION\",\r\n            \"menuItemId\": 4547\r\n        }, {\r\n            \"menuAttributeId\": 999999,\r\n            \"menuAttributeValue\": \"[{\\\"menuAttributeId\\\":25350,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isOnbehalfOf\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25351,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isComponent\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25352,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isFeedback\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25353,\\\"menuAttributeValue\\\":\\\"asd\\\",\\\"attributeKey\\\":\\\"instanceKey\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25354,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isOpenWithPopup\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25355,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isRedirected\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25356,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isCustomerSession\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25357,\\\"menuAttributeValue\\\":\\\"6546\\\",\\\"attributeKey\\\":\\\"whiteListVpn\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25358,\\\"menuAttributeValue\\\":\\\"9879\\\",\\\"attributeKey\\\":\\\"blackListVpn\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25359,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isOnbehalfOf\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25360,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isComponent\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25361,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isFeedback\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25362,\\\"menuAttributeValue\\\":\\\"asd\\\",\\\"attributeKey\\\":\\\"instanceKey\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25363,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isOpenWithPopup\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25364,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isRedirected\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25365,\\\"menuAttributeValue\\\":\\\"1\\\",\\\"attributeKey\\\":\\\"isCustomerSession\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25366,\\\"menuAttributeValue\\\":\\\"6546\\\",\\\"attributeKey\\\":\\\"whiteListVpn\\\",\\\"menuItemId\\\":4547},{\\\"menuAttributeId\\\":25367,\\\"menuAttributeValue\\\":\\\"9879\\\",\\\"attributeKey\\\":\\\"blackListVpn\\\",\\\"menuItemId\\\":4547}]\",\r\n            \"attributeKey\": \"ATTRIBUTEKEY_REGULATION\",\r\n            \"menuItemId\": 999999\r\n        }\r\n        ],\r\n        \"menuRegLinkList\": []\r\n    }\r\n    return mockDataMenuItem;\r\n}",
					"TO": 1,
					"HL": "TS"
				},
				"retrieveJsonData": {
					"H": "declare let onlineApproveId;\r\n\r\nlet requestData: any = {\r\n    \"onlineApproveId\": onlineApproveId\r\n};\r\n\r\nlet serviceRequest: any = {};\r\n\r\nserviceRequest.blockRender = '';\r\nserviceRequest.data = requestData;\r\nserviceRequest.url = 'PREFIX/api/MenuOperationsApp/retrieveJsonData';\r\nserviceRequest.http = 'POST';\r\nserviceRequest.responseField = {};\r\nlet responseField: any = 'retrieveJsonDataResponse';\r\nserviceRequest.responseField = responseField;\r\nserviceRequest.onSuccess = 'retrieveJsonDataRequestSuccess';\r\nserviceRequest.onFail = 'retrieveJsonDataRequestFail';\r\n// quick.store.set('$customConsumerCode', quick.store.get('customConsumerCode'));\r\nquick.Request.async(serviceRequest);",
					"C": true,
					"HL": "TS"
				},
				"retrieveJsonDataRequestSuccess": {
					"H": "let mockData = quick.store.get('mockData');\r\n\r\nlet responseData = mockData ?? response.retrieveJsonDataResponse;\r\n\r\nlet params = quick.store.get('urlParams');\r\ndebugger\r\nif (params?.islemTipi == 'updateMenu') {\r\n    let tableHeaders = [{ 'text': 'İşlem Bilgileri', 'align': 'start', 'sortable': false, 'value': 'label','width':'100px' },\r\n    { 'text': 'Eski Değerler', 'value': 'oldValue', 'sortable': false, 'width': '500px'  },\r\n    { 'text': 'Yeni Değerler', 'value': 'newValue', 'sortable': false, 'width': '500px' }];\r\n\r\n    components.tbl_details.headers = tableHeaders;\r\n\r\n    quick.store.set('jsonData', responseData);\r\n\r\n    quick.MM.trigger('retrieveMenuItem', [{ 'menuId': params.menuId }]);\r\n}\r\nelse if (params?.islemTipi == 'insertNewMenu') {\r\n    let tableHeaders = [{ 'text': 'İşlem Bilgileri', 'align': 'start', 'sortable': false, 'value': 'label','width':'100px' },\r\n    { 'text': 'Yeni Değerler', 'value': 'newValue', 'sortable': false,'width': '500px' }];\r\n\r\n    components.tbl_details.headers = tableHeaders;\r\n\r\n    // isCustomer \r\n\r\n    let isCustomer = '';\r\n    if (responseData?.isCustomer?.includes('1'))\r\n        isCustomer += ', Oturum İçi';\r\n    if (responseData?.isCustomer?.includes('0'))\r\n        isCustomer += ', Oturum Dışı';\r\n    if (responseData?.isCustomer?.includes('2'))\r\n        isCustomer += ', Aday';\r\n    isCustomer = isCustomer.slice(2) != '' ? isCustomer.slice(2) : '-';\r\n\r\n\r\n    // customerType\r\n    let customerType = '';\r\n    if (responseData?.customerType?.includes('1'))\r\n        customerType += ', Bireysel';\r\n    if (responseData?.customerType?.includes('2'))\r\n        customerType += ', Ticari';\r\n    if (responseData?.customerType?.includes('3'))\r\n        customerType += ', GKT';\r\n    customerType = customerType.slice(2) != '' ? customerType.slice(2) : '-';\r\n\r\n\r\n    // branchType\r\n    let branchType = '';\r\n    if (responseData?.branchType?.includes('B'))\r\n        branchType += ', Bireysel';\r\n    if (responseData?.branchType?.includes('P'))\r\n        branchType += ', Karma';\r\n    if (responseData?.branchType?.includes('T'))\r\n        branchType += ', Ticari';\r\n    if (responseData?.branchType?.includes('K'))\r\n        branchType += ', Kurumsal';\r\n    branchType = branchType.slice(2) != '' ? branchType.slice(2) : '-';\r\n    \r\n    let items = [\r\n        { 'label': 'Menü Adı', 'newValue': responseData?.menuName ?? '-' },\r\n        { 'label': 'Menü Url', 'newValue': responseData?.menuUrl ?? '-' },\r\n        { 'label': 'Menü Sırası', 'newValue': responseData?.position ?? '-' },\r\n        { 'label': 'Uygulama Sahibi', 'newValue': responseData?.appOwner ?? '-' },\r\n        { 'label': 'Uygulama Tipi', 'newValue': responseData?.appType ?? '-' },\r\n        { 'label': 'Link/Menü', 'newValue': responseData?.isCaption == 'LEAF' ? 'Link' : 'Menü' },\r\n        { 'label': 'Yayınlanma Tarihi', 'newValue': responseData?.publishDate ? (<any>new Date(responseData?.publishDate).toLocaleDateString('TR-tr')).replaceAll('.', '/') : '-' },\r\n        { 'label': 'Yetkiler', 'newValue': responseData?.rightNames ?? '-' },\r\n        { 'label': 'Beyaz Liste (Pilot Şube)', 'newValue': responseData?.whiteList ?? '-' },\r\n        { 'label': 'Kara Liste', 'newValue': responseData?.blackList ?? '-' },\r\n        { 'label': 'Beyaz Liste (VPN)', 'newValue': responseData?.whiteListVpn ?? '-' },\r\n        { 'label': 'Kara Liste (VPN)', 'newValue': responseData?.blackListVpn ?? '-' },\r\n        { 'label': 'Yardım Linki', 'newValue': responseData?.helpLink ?? '-' },\r\n        { 'label': 'Oturum İçi/Dışı', 'newValue': isCustomer ?? '-' },\r\n        { 'label': 'Müşteri Tipi', 'newValue': customerType ?? '-' },\r\n        { 'label': 'Şube Tipi', 'newValue': branchType ?? '-' },\r\n        { 'label': 'Segment', 'newValue': responseData?.segment ?? '-' },\r\n        { 'label': 'Yeni İkonu', 'newValue': responseData?.isNew ?? '-' },\r\n        { 'label': 'Ürün Kodu', 'newValue': responseData?.productCode ?? '-' },\r\n        { 'label': 'Geçici olarak kapatılsın mı?', 'newValue': responseData?.temporaryClosed == 1 ? 'Evet' : 'Hayır' },\r\n        { 'label': 'Ekran maksimum açılsın mı?', 'newValue': responseData?.isMaximized == 1 ? 'Evet' : 'Hayır' },\r\n        { 'label': 'Mevzuat Etiketi', 'newValue': responseData?.regulationTag ?? '-' },\r\n        { 'label': 'Mevzuat Linkleri', 'newValue': responseData?.regLinks ?? '-' }\r\n    ];\r\n    \r\n    components.tbl_details.items = items;\r\n}\r\nelse {\r\n    // hata\r\n    // işlem tipi bulunamadı\r\n}\r\n",
					"C": true,
					"HL": "TS"
				},
				"retrieveJsonDataRequestFail": {
					"H": "let mockData = quick.store.get('mockData');\r\n\r\nif (mockData)\r\n    quick.MM.trigger('retrieveJsonDataRequestSuccess');",
					"C": true,
					"HL": "TS"
				},
				"retrieveMenuItem": {
					"H": "declare let menuId;\r\n\r\nquick.store.delete('menuItemData');\r\n\r\nlet requestData: any = {\r\n    menuId: menuId\r\n};\r\n\r\nlet serviceRequest: any = {};\r\n\r\nserviceRequest.blockRender = '';\r\nserviceRequest.data = requestData;\r\nserviceRequest.url = 'PREFIX/api/MenuOperationsApp/retrieveMenuItem';\r\nserviceRequest.http = 'POST';\r\nserviceRequest.responseField = {};\r\nlet responseField: any = 'retrieveMenuItemResponse';\r\nserviceRequest.responseField = responseField;\r\nserviceRequest.onSuccess = 'retrieveMenuItemRequestSuccess';\r\nserviceRequest.onFail = 'retrieveMenuItemRequestFail';\r\nquick.store.set('$customConsumerCode', quick.store.get('customConsumerCode'));\r\nquick.Request.async(serviceRequest);",
					"C": true,
					"HL": "TS"
				},
				"retrieveMenuItemRequestSuccess": {
					"H": "let responseData = quick.store.get('mockDataMenuItem') ?? response?.retrieveMenuItemResponse;\r\n\r\nlet newAttributeList = quick.Quick.copy(responseData?.menuAttributeList);\r\n\r\nif (responseData?.menuAttributeList?.length > 0) {\r\n    let tmpAttRegulation = [];\r\n    responseData?.menuAttributeList?.forEach((att) => {\r\n        if (att?.menuAttributeId == 999999 && att?.attributeKey == 'ATTRIBUTEKEY_REGULATION') {\r\n            tmpAttRegulation = JSON.parse(att?.menuAttributeValue);\r\n        }\r\n        else if (att?.menuAttributeId != 999999 && att?.attributeKey == 'ATTRIBUTEKEY_REGULATION') {\r\n            quick.store.set('isBirimi', att?.menuAttributeValue);\r\n        }\r\n    });\r\n\r\n    if (tmpAttRegulation?.length > 0) {\r\n        tmpAttRegulation?.forEach((att) => {\r\n            att.attributeKey = 'ATTRIBUTEKEY_' + att?.attributeKey?.toUpperCase();\r\n\r\n            const tmpAtt = newAttributeList.find(item => item.attributeKey === att.attributeKey);\r\n\r\n            if (tmpAtt) {\r\n                tmpAtt.menuAttributeValue = att.menuAttributeValue;\r\n            }\r\n            else {\r\n                newAttributeList.push(att);\r\n            }\r\n        });\r\n    }\r\n}\r\n\r\nlet jsonData = quick.store.get('jsonData');\r\nlet oldMenuOffering = responseData?.menuOffering;\r\nlet oldMenuRightList = '';\r\nresponseData?.menuRightList?.forEach((item) => {\r\n    oldMenuRightList += ', ' + item?.menuRightName;\r\n});\r\noldMenuRightList = oldMenuRightList.slice(2) != '' ? oldMenuRightList.slice(2) : '-';\r\nlet oldMenuAttributeList = newAttributeList;\r\n\r\n// isCustomer \r\n\r\nlet isCustomer = '';\r\nif (jsonData?.isCustomer?.includes('1'))\r\n    isCustomer += ', Oturum İçi';\r\nif (jsonData?.isCustomer?.includes('0'))\r\n    isCustomer += ', Oturum Dışı';\r\nif (jsonData?.isCustomer?.includes('2'))\r\n    isCustomer += ', Aday';\r\nisCustomer = isCustomer.slice(2) != '' ? isCustomer.slice(2) : '-';\r\n\r\nlet oldIsCustomer = '';\r\nlet oldIsCustomerValue = oldMenuAttributeList.find(item => item.attributeKey == 'ATTRIBUTEKEY_ISCUSTOMER')?.menuAttributeValue ?? '';\r\nif (oldIsCustomerValue?.includes('1'))\r\n    oldIsCustomer += ', Oturum İçi';\r\nif (oldIsCustomerValue?.includes('0'))\r\n    oldIsCustomer += ', Oturum Dışı';\r\nif (oldIsCustomerValue?.includes('2'))\r\n    oldIsCustomer += ', Aday';\r\noldIsCustomer = oldIsCustomer.slice(2) != '' ? oldIsCustomer.slice(2) : '-';\r\n\r\n\r\n// customerType\r\nlet customerType = '';\r\nif (jsonData?.customerType?.includes('1'))\r\n    customerType += ', Bireysel';\r\nif (jsonData?.customerType?.includes('2'))\r\n    customerType += ', Ticari';\r\nif (jsonData?.customerType?.includes('3'))\r\n    customerType += ', GKT';\r\ncustomerType = customerType.slice(2) != '' ? customerType.slice(2) : '-';\r\n\r\nlet oldCustomerType = '';\r\nlet oldCustomerTypeValues = oldMenuAttributeList.find(item => item.attributeKey == 'ATTRIBUTEKEY_CUSTOMERTYPE')?.menuAttributeValue ?? '';\r\nif (oldCustomerTypeValues?.includes('1'))\r\n    oldCustomerType += ', Bireysel';\r\nif (oldCustomerTypeValues?.includes('2'))\r\n    oldCustomerType += ', Ticari';\r\nif (oldCustomerTypeValues?.includes('3'))\r\n    oldCustomerType += ', GKT';\r\noldCustomerType = oldCustomerType.slice(2) != '' ? oldCustomerType.slice(2) : '-';\r\n\r\n\r\n// branchType\r\nlet branchType = '';\r\nif (jsonData?.branchType?.includes('B'))\r\n    branchType += ', Bireysel';\r\nif (jsonData?.branchType?.includes('P'))\r\n    branchType += ', Karma';\r\nif (jsonData?.branchType?.includes('T'))\r\n    branchType += ', Ticari';\r\nif (jsonData?.branchType?.includes('K'))\r\n    branchType += ', Kurumsal';\r\nbranchType = branchType.slice(2) != '' ? branchType.slice(2) : '-';\r\n\r\nlet oldBranchType = '';\r\nlet oldBranchTypeValues = oldMenuAttributeList.find(item => item.attributeKey == 'ATTRIBUTEKEY_BRANCHTYPE')?.menuAttributeValue ?? '';\r\nif (oldBranchTypeValues?.includes('B'))\r\n    oldBranchType += ', Bireysel';\r\nif (oldBranchTypeValues?.includes('P'))\r\n    oldBranchType += ', Karma';\r\nif (oldBranchTypeValues?.includes('T'))\r\n    oldBranchType += ', Ticari';\r\nif (oldBranchTypeValues?.includes('K'))\r\n    oldBranchType += ', Kurumsal';\r\noldBranchType = oldBranchType.slice(2) != '' ? oldBranchType.slice(2) : '-';\r\n\r\nlet items = [\r\n    { 'label': 'Menü Adı', 'oldValue': oldMenuOffering?.menuName ?? '-', 'newValue': jsonData?.menuName ?? '-' },\r\n    { 'label': 'Menü Url', 'oldValue': oldMenuOffering?.menuUrl ??'-', 'newValue': jsonData?.menuUrl ?? '-' },\r\n    { 'label': 'Menü Sırası', 'oldValue': oldMenuOffering?.menuPosition ?? '-', 'newValue': jsonData?.position ?? '-' },\r\n    { 'label': 'Uygulama Sahibi', 'oldValue': oldMenuOffering?.menuAppOwner ?? '-', 'newValue': jsonData?.appOwner ?? '-' },\r\n    { 'label': 'Uygulama Tipi', 'oldValue': oldMenuOffering?.menuAppType ?? '-', 'newValue': jsonData?.appType ?? '-' },\r\n    { 'label': 'Link/Menü', 'oldValue': oldMenuOffering?.menuIsCaption == 'LEAF' ? 'Link' : 'Menü', 'newValue': jsonData?.isCaption == 'LEAF' ? 'Link' : 'Menü' },\r\n    { 'label': 'Yayınlanma Tarihi', 'oldValue': oldMenuOffering?.menuPublishDate ? (<any>new Date(oldMenuOffering?.menuPublishDate).toLocaleDateString('TR-tr')).replaceAll('.', '/') : '-', 'newValue': jsonData?.publishDate ? (<any>new Date(jsonData?.publishDate).toLocaleDateString('TR-tr')).replaceAll('.', '/') : '-' },\r\n    { 'label': 'Yetkiler', 'oldValue': oldMenuRightList ?? '-', 'newValue': jsonData?.rightNames ?? '-' },\r\n    { 'label': 'Mevzuat Linkleri', 'oldValue': '-', 'newValue': '-' },\r\n    { 'label': 'Beyaz Liste (Pilot Şube)', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_WHITELIST')?.menuAttributeValue ?? '-', 'newValue': jsonData?.whiteList ?? '-' },\r\n    { 'label': 'Kara Liste', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_BLACKLIST')?.menuAttributeValue ?? '-', 'newValue': jsonData?.blackList ?? '-' },\r\n    { 'label': 'Beyaz Liste (VPN)', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_WHITELISTVPN')?.menuAttributeValue ?? '-', 'newValue': jsonData?.whiteListVpn ?? '-' },\r\n    { 'label': 'Kara Liste (VPN)', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_BLACKLIST')?.menuAttributeValue ?? '-', 'newValue': jsonData?.blackListVpn ?? '-' },\r\n    { 'label': 'Yardım Linki', 'oldValue': oldMenuOffering?.menuHelpLink ?? '-', 'newValue': jsonData?.helpLink ?? '-' },\r\n    { 'label': 'Oturum İçi/Dışı', 'oldValue': oldIsCustomer ?? '-', 'newValue': isCustomer ?? '-' },\r\n    { 'label': 'Müşteri Tipi', 'oldValue': oldCustomerType ?? '-', 'newValue': customerType ?? '-' },\r\n    { 'label': 'Şube Tipi', 'oldValue': oldBranchType ?? '-', 'newValue': branchType ?? '-' },\r\n    { 'label': 'Segment', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_SEGMENT')?.menuAttributeValue ?? '-', 'newValue': jsonData?.segment ?? '-' },\r\n    { 'label': 'Yeni İkonu', 'oldValue': '-', 'newValue': jsonData?.isNew ?? '-' },\r\n    { 'label': 'Ürün Kodu', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_PRODUCTCODE')?.menuAttributeValue ?? '-', 'newValue': jsonData?.productCode ?? '-' },\r\n    { 'label': 'Geçici olarak kapatılsın mı?', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_TEMPRORYCLOSED')?.menuAttributeValue == '1' ? 'Evet' : 'Hayır', 'newValue': jsonData?.temporaryClosed == 1 ? 'Evet' : 'Hayır' },\r\n    { 'label': 'Ekran maksimum açılsın mı?', 'oldValue': oldMenuAttributeList?.find(item => item?.attributeKey == 'ATTRIBUTEKEY_ISMAXIMIZED')?.menuAttributeValue == '1' ? 'Evet' : 'Hayır', 'newValue': jsonData?.isMaximized == 1 ? 'Evet' : 'Hayır' },\r\n    { 'label': 'Mevzuat Etiketi', 'oldValue': oldMenuAttributeList?.find(item => (item?.attributeKey == 'ATTRIBUTEKEY_REGULATION' && item?.menuAttributeId != 999999))?.menuAttributeValue, 'newValue': jsonData?.regulationTag ?? '-' },\r\n    { 'label': 'Mevzuat Linkleri', 'oldValue': '-', 'newValue': jsonData?.regLinks ?? '-' }\r\n];\r\n\r\ncomponents.tbl_details.items = items;\r\n",
					"C": true,
					"HL": "TS"
				},
				"retrieveMenuItemRequestFail": {
					"H": "let mockDataMenuItem = quick.store.get('mockDataMenuItem');\r\n\r\nif (mockDataMenuItem)\r\n    quick.MM.trigger('retrieveMenuItemRequestSuccess');\r\n\r\n\r\n// declare let error\r\n\r\n// // components.lbl_diaError.text = error?.response?.data ?? 'Menü bilgisi alınırken bir hata oluştu. Bağlantınızı kontrol edip tekrar deneyin.';\r\n// quick.store.set('errorPostProcess', errorPostProcess);\r\n// // components.dia_error.qValue = true;\r\n\r\n\r\n// function errorPostProcess() { }",
					"C": true,
					"HL": "TS"
				}
			},
