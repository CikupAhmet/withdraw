let pjson = {
	"pJson": [
		{
			"T": "Messaging",
			"P": {
				"ID": {
					"H": "PageComp",
					"T": "prop"
				},
				"triggerOnRestored": {
					"H": "false",
					"T": "prop"
				}
			},
			"E": {
				"ofsaaRequest": {
					"H": "declare const operationCode;\r\ndeclare const pcuBytes;\r\ndeclare const monetaryType;\r\n\r\nlet jsonData = quick.store.get(\"jsonData\");\r\n\r\nlet accountNumber = jsonData.accountNumber\r\nlet branchCode = jsonData.accountBranchCode\r\nlet currencyCode = jsonData.currency\r\nlet customerNumber = quick.store.get(\"customerValue\");\r\nlet transactionCode = \"NakitYat\"\r\n\r\nif (jsonData.operationType == 0) {\r\n    quick.store.set(\"$customConsumerCode\",'TANE.DEPDEPOSIT');\r\n} else {\r\n    quick.store.set(\"$customConsumerCode\",'TANE.DEPWITHDRAW');\r\n    transactionCode = \"NakitCek\"\r\n}\r\n\r\nlet userContext = quick.containerServices.getUserContext() as any;\r\n\r\nlet isbClientHeader = JSON.parse(quick.containerServices.extensions.getHeader('','isbClient'));\r\nlet consumerHeader = JSON.parse(quick.containerServices.extensions.getHeader('','consumer'));\r\n\r\nlet tellerId = isbClientHeader[\"branch-v1\"]?.tellerId;\r\nlet organizationUnitCode = isbClientHeader[\"branch-v1\"]?.organizationUnitCode;\r\nlet employeeId = userContext?.userid;\r\nlet channelCode = consumerHeader[\"branchContextV1\"]?.channelCode;\r\n\r\nlet tod = 'CHECK';\r\nlet sequenceNo = 1;\r\n\r\nif (response.responseVirementCreate) {\r\n  tod = response.responseVirementCreate.result.tod\r\n  sequenceNo = response.responseVirementCreate.result.sequenceNo\r\n}\r\n\r\nlet requestData = {\r\n  part: \"0\",\r\n  type: \"A\",\r\n  groupType: \"X011\", \r\n  customerNumber: customerNumber,\r\n  accountNumber: {\r\n    branchCode: branchCode,\r\n    number: accountNumber\r\n  },\r\n  tod: tod,\r\n  amount: quick.Quick.toDecimal(jsonData.amount, \",\").toString(),\r\n  tellerId: tellerId,\r\n  sequenceNo: sequenceNo,\r\n  employeeId: employeeId,\r\n  processingOrganizationUnit: organizationUnitCode,\r\n  productCode: \"5\",\r\n  channelCode: channelCode,\r\n  transactionCode: transactionCode,\r\n  operationCode: operationCode, // check-virement K, virement O \r\n  pcuBytes: pcuBytes, // hatalı olursa R, başarılı A \r\n  currencySwiftCode: currencyCode,\r\n  monetaryType: monetaryType, // check-virement Z, virement P \r\n  abmDetails: { \r\n    isVoucherPrintingNecessary: \"3\"\r\n  },\r\n  accountType: \"1\", \r\n};\r\n\r\n\r\nconst req: IRequest = {\r\n  url: \"/api/dep-operations/v1/api/dep-operations/create-ofsaa\",\r\n  data: requestData,\r\n  blockRender: false,\r\n  http: \"POST\",\r\n  onFail: \"onFailOfsaRequest\",\r\n  onSuccess: \"onSuccessOfsaRequest\",\r\n  responseField: \"ofsaResponse\",\r\n  timeout: 200000,\r\n};\r\n\r\nquick.Request.async(req);",
					"C": true,
					"HL": "TS"
				},
				"EndRender": {
					"H": "quick.store.set(\"successVirement\", false);\r\nlet params = quick.Url.getDeepLinkParams();\r\nquick.EM.trace(\"url\")\r\nquick.EM.trace(params);\r\n//  \r\n\r\nlet accountListRequest: IRequest = {\r\n    url: 'PREFIX/api/dep-operations/v1/api/dep-operations/retrieveOnlineApprove?approveId=' + params?.onlineApproveId,\r\n    http: 'get',\r\n    blockRender: true,\r\n    onSuccess: 'onSuccessRetrieveOnlineApprove',\r\n    onFail: 'onFaiRetrieveOnlineApprove',\r\n    responseField: 'retrieveOnlineApprove',\r\n    data: null\r\n}\r\nquick.Request.async(accountListRequest);\r\n\r\nlet idempotentRequest: IRequest = {\r\n    url: 'PREFIX/api/dep-operations/v1/api/dep-operations/keys',\r\n    http: 'get',\r\n    blockRender: true,\r\n    onSuccess: 'onSuccessIdempotent',\r\n    onFail: 'onFailIdempotent',\r\n    responseField: 'idempotent',\r\n    data: null\r\n}\r\nquick.Request.async(idempotentRequest);",
					"HL": "TS"
				},
				"onSuccessRetrieveOnlineApprove": {
					"H": "quick.EM.trace(\"onSuccessRetrieveOnlineApprove\")\r\nquick.EM.trace(response.retrieveOnlineApprove)\r\n\r\nlet onlineApprove = response.retrieveOnlineApprove;\r\n\r\nif (onlineApprove.operationType == 'deposit') {\r\n    components.summaryDebitAccount.label = 'Paranının Yatırılacağı Hesap'\r\n    components.HeaderSummary.text = 'Müşterinin Hesabına Nakit Para Yatırma İşlem Onay';\r\n} else {\r\n    components.summaryDebitAccount.label = 'Paranının Çekileceği Hesap'\r\n    components.HeaderSummary.text = 'Müşterinin Hesabından Nakit Para Çekme İşlem Onay';\r\n}\r\n\r\nconst formattedAccountBalance = new Intl.NumberFormat(\"tr-TR\", {\r\n    minimumFractionDigits: 2,\r\n    maximumFractionDigits: 2\r\n    }).format(onlineApprove.accountBalance);\r\n\r\nconst formattedMainAmount = new Intl.NumberFormat(\"tr-TR\", {\r\n    minimumFractionDigits: 2,\r\n    maximumFractionDigits: 2\r\n    }).format(onlineApprove.amount);\r\n\r\ncomponents.summaryDebitAccount.qValue = onlineApprove.branchCode + ' - ' + onlineApprove.accountIban + ' - ' + formattedAccountBalance + ' ' + onlineApprove.currency\r\ncomponents.summaryDescription.qValue = onlineApprove.description;\r\ncomponents.summaryAmount.qValue = formattedMainAmount + ' ' + onlineApprove.currency;\r\n\r\nif (onlineApprove.feeAmountResponse?.feeAmount != null && onlineApprove.feeAmountResponse?.feeAmount?.unscaledValue > 0) {\r\n    let scaledValue = Number(onlineApprove.feeAmountResponse.feeAmount.unscaledValue) / Math.pow(10, 2);\r\n    let bsmv = Number(onlineApprove.feeAmountResponse.feeAmountBsmv.unscaledValue) / Math.pow(10, 2);\r\n    let totalAmount = scaledValue + bsmv;\r\n\r\n    const formattedResultTax = new Intl.NumberFormat(\"tr-TR\", {\r\n      minimumFractionDigits: 2,\r\n      maximumFractionDigits: 2\r\n    }).format(bsmv);\r\n\r\n    const formattedAmount = new Intl.NumberFormat(\"tr-TR\", {\r\n        minimumFractionDigits: 2,\r\n        maximumFractionDigits: 2\r\n        }).format(scaledValue);\r\n\r\n    const formattedTotalAmount = new Intl.NumberFormat(\"tr-TR\", {\r\n        minimumFractionDigits: 2,\r\n        maximumFractionDigits: 2\r\n        }).format(totalAmount);\r\n\r\n    if (onlineApprove.feeAmountResponse.feePaymentType == 'CASH') {\r\n        components.paymentType.qValue = 'Nakit'\r\n    } else {\r\n        components.paymentType.qValue = 'Vadesiz Hesaptan Tahsil Edilecek'\r\n        \r\n        components.feeAnotherAccountInfo.visible = true;\r\n    }\r\n\r\n    components.feeAmount.qValue = formattedAmount;\r\n    components.feeTaxAmount.qValue = formattedResultTax;\r\n    components.feeTotalAmount.qValue = formattedTotalAmount;\r\n\r\n    components.feeRow.visible = true;\r\n    components.feeAmount.visible = true;\r\n    components.feeTaxAmount.visible = true;\r\n    components.feeTotalAmount.visible = true;\r\n    components.paymentType.visible = true;\r\n} ",
					"C": true,
					"HL": "TS"
				},
				"onSuccessIdempotent": {
					"H": "quick.EM.trace(\"onSuccessIdempotent\")\r\nquick.EM.trace(response.onSuccessIdempotent)",
					"C": true,
					"HL": "TS"
				}
			},
