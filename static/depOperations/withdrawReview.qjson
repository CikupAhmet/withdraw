																																				},
																																				"visible": {
																																					"H": "true",
																																					"T": "prop"
																																				},
																																				"DiscardSettings": {
																																					"H": "true",
																																					"T": "prop",
																																					"HL": "QS"
																																				}
																																			},
																																			"E": {
																																				"click": {
																																					"H": "quick.EM.trace(\"Onaya gitmedi\")\r\nquick.store.set(\"$customConsumerCode\",'TANE.DEPVIREMENT');\r\nlet successVirementB4 = quick.store.get(\"successVirement\");\r\nif (successVirementB4 == true) {\r\n\r\n    quick.containerServices.extensions.closeWindow();\r\n} else {\r\n    components.approveButton.disabled = true\r\n    let virementRequest: any = {};\r\n\r\n    let onlineApprove = response.retrieveOnlineApprove\r\n    quick.EM.trace(onlineApprove);\r\n\r\n    let accountId = onlineApprove.accountId;\r\n    //let amount = quick.Quick.toDecimal(onlineApprove.amount, \",\").toString();\r\n    let currencyCode = onlineApprove.currency;\r\n    let description = onlineApprove.description;\r\n    let idempotent = response.idempotent.firstIdempotent\r\n\r\n    /*let feeAmountResponse = response.responseCheckWithdrawCreate?.feeAmountResponse;\r\n    let feeAccountId = undefined;\r\n    let feeAccountNumber = undefined;\r\n    let feeAccountBranchCode = undefined;\r\n\r\n    let feePaymentType = quick.store.get(\"feePaymentType\")\r\n    if(feePaymentType === \"ANOTHER_ACCOUNT\") {\r\n        feeAccountId = feeAccountInfo.accountId;\r\n        feeAccountNumber = feeAccountInfo.accountNumber;\r\n        feeAccountBranchCode = feeAccountInfo.branchCode;\r\n    }\r\n\r\n    const newResponse = {\r\n        ...feeAmountResponse,\r\n        feeAccountId: feeAccountId,\r\n        feeAccountNumber: feeAccountNumber,\r\n        feeAccountBranchCode: feeAccountBranchCode,\r\n        feePaymentType: feePaymentType\r\n    }\r\n    */\r\n\r\n    if (onlineApprove.feeAmountResponse != null && onlineApprove.feeAmountResponse.feePaymentType == null) {\r\n        onlineApprove.feeAmountResponse.feePaymentType = 'CASH';\r\n    }\r\n    \r\n    virementRequest.amount = onlineApprove.amount;\r\n    virementRequest.currencyCode = currencyCode;\r\n    virementRequest.description = description;\r\n    virementRequest.feeAmountResponse = onlineApprove.feeAmountResponse;\r\n    \r\n\r\n    let urlNew = '';\r\n\r\n    if (onlineApprove.operationType == 'deposit') {\r\n        urlNew = 'PREFIX/api/dep-operations/v1/api/dep-operations/deposit'\r\n        virementRequest.creditAccountId = accountId;\r\n        quick.store.set(\"$customConsumerCode\",'TANE.DEPDEPOSIT');\r\n    } else {\r\n        urlNew = 'PREFIX/api/dep-operations/v1/api/dep-operations/withdraw'\r\n        virementRequest.debitAccountId = accountId;\r\n        quick.store.set(\"$customConsumerCode\",'TANE.DEPWITHDRAW');\r\n    }\r\n    \r\n    quick.store.set(\"$customCustomerNumber\",onlineApprove.customerId);\r\n    quick.store.set(\"$customUserId\",onlineApprove.userId);\r\n\r\n\r\n    let withdrawCreateRequest: IRequest = {\r\n        url: urlNew,\r\n        http: 'post',\r\n        headers: { \"x-rly-idempotency-key\":  idempotent},\r\n        blockRender: true,\r\n        onSuccess: 'onSuccessWithdrawCreate',\r\n        onFail: 'onFailWithdrawCreate',\r\n        responseField: 'responseWithdrawCreate',\r\n        data: virementRequest\r\n    }\r\n    quick.Request.async(withdrawCreateRequest);\r\n}\r\n\r\n",
																																					"P": "mouseEvent:unknown | undefined",
																																					"HL": "TS"
																																				},
																																				"onSuccessWithdrawCreate": {
																																					"H": "quick.EM.trace(\"onSuccessWithdrawCreate\")\r\nquick.store.set(\"successVirement\", true);\r\n\r\nquick.EM.trace(response.responseWithdrawCreate);\r\ncomponents.approveButton.disabled = false;\r\nlet onlineApprove = response.retrieveOnlineApprove;\r\nlet successText = \"İşlem başarı ile gerçekleşti. Lütfen \" + onlineApprove.amount + \" TL tahsil ediniz.\"\r\n\r\nif (onlineApprove.operationTypeGroup.qValue == 0) {\r\n    components.HeaderSummary.text = 'Müşterinin Hesabına Nakit Para Yatırma İşlem Sonuç';\r\n} else {\r\n    components.HeaderSummary.text = 'Müşterinin Hesabından Nakit Para Çekme İşlem Sonuç';\r\n    successText = \"İşlem başarı ile gerçekleşti. Lütfen \" + onlineApprove.amount + \" TL ödeyiniz.\"\r\n}\r\n\r\ncomponents.approveButtonText.text = 'Bitir';\r\ncomponents.closeButton.visible = false;\r\n\r\nquick.MM.trigger(\"ofsaaRequest\", [{operationCode: \"O\", pcuBytes: \"A\", monetaryType: \"K\"}]);\r\n\r\nif (response.responseWithdrawCreate) {\r\n    let date = response.responseWithdrawCreate.timestamp;\r\n    quick.EM.trace(\"date\");\r\n    quick.EM.trace(date)\r\n    let correlationId = response.responseWithdrawCreate.result.correlationId;\r\n    quick.EM.trace(\"correlationId\", correlationId)\r\n    quick.EM.trace(correlationId);\r\n    const url = \"date=\" + date + \"&siid=\" + correlationId.toUpperCase();\r\n\r\n    quick.EM.trace(\"dekont-url\")\r\n    quick.EM.trace(url);\r\n\r\n    quick.containerServices.extensions.showVoucherPopUp(url);\r\n}\r\n\r\n\r\ncomponents.successDialogVirement.dialogClick({ text: successText});\r\n\r\n\r\n",
																																					"C": true,
																																					"HL": "TS"
																																				},
																																				"onFailWithdrawCreate": {
																																					"H": "quick.EM.trace(\"fail\")\r\n\r\ndeclare var error;\r\n\r\nquick.EM.trace('onFailVirementCreate')\r\n\r\nquick.store.set(\"successVirement\", false);\r\ncomponents.approveButton.disabled = false\r\n\r\nquick.MM.trigger(\"ofsaaRequest\", [{operationCode: \"O\", pcuBytes: \"R\", monetaryType: \"P\"}]);\r\n\r\n\r\n\r\nlet errorMessage = \"\";\r\n\r\nif (error.response) {\r\n    if (error.response.data.responseMessage) {\r\n        errorMessage = error.response.data.responseMessage\r\n    } else {\r\n        errorMessage = \"Beklenmedik bir hata oluştu.\"\r\n    }\r\n}\r\n\r\ncomponents.errorDialogVirement.dialogClick({ text: errorMessage});\r\n\r\n",
																																					"C": true,
																																					"HL": "TS"
																																				}
																																			},
