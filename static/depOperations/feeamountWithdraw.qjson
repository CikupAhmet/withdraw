				"externalEvents": {
					"H": "[{name='searchClickEvent', params=['feeAccountInfo', 'feePaymentType']}]",
					"T": "prop",
					"HL": "QS"
				}
			},
			"E": {
				"dialogClick": {
					"H": "declare const amount;\r\ndeclare const currency;\r\ndeclare const accountList;\r\ndeclare const feeAmountResponse;\r\ncomponents.lblWarn.text = \"Ücret Bilgileri\"\r\ncomponents.warnDialog.qValue = true\r\n\r\ncomponents.type.qValue = undefined;\r\n\r\nquick.MM.trigger('setAmount', [{amount:amount, currency:currency, accountList:accountList, feeAmountResponse: feeAmountResponse}]);\r\n",
					"C": true,
					"EV": true,
					"HL": "TS"
				},
				"setAmount": {
					"H": "quick.EM.trace(\"setAmount\")\r\ndeclare const amount;\r\ndeclare const currency;\r\ndeclare const accountList;\r\ndeclare const feeAmountResponse;\r\nquick.store.set(\"feeAmountResponse\", feeAmountResponse)\r\nquick.EM.trace(\"feeAmountDialogSet\")\r\nquick.EM.trace(accountList)\r\n\r\nif (feeAmountResponse.customizationAllowed) {\r\n    components.totalAmount.readonly = false;\r\n}\r\n\r\nlet scaledValue = Number(feeAmountResponse.feeAmount.unscaledValue) / Math.pow(10, 2);\r\nlet bsmv = Number(feeAmountResponse.bsmv.unscaledValue) / Math.pow(10, 5)\r\n\r\nlet taxAmount = scaledValue * bsmv;\r\n\r\nconst formattedResultTax = new Intl.NumberFormat(\"tr-TR\", {\r\n      minimumFractionDigits: 2,\r\n      maximumFractionDigits: 2\r\n    }).format(taxAmount);\r\n\r\ncomponents.taxAmount.qValue = formattedResultTax;\r\ncomponents.amount.qValue = amount;\r\ncomponents.currency.qValue = currency;\r\ncomponents.anotherAccountInfo.items = accountList;",
					"C": true,
					"HL": "TS"
				}
			},
