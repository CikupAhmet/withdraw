																															"E": {
																																"click": {
																																	"H": "let check = false;\r\nlet checkAccount = true;\r\n\r\nquick.EM.trace(components.type.qValue)\r\nquick.EM.trace(components.anotherAccountInfo.qValue)\r\n\r\nif (components.type.qValue) {\r\n    check = true;\r\n}\r\n\r\nif (components.type.qValue.value == 'ANOTHER_ACCOUNT') {\r\n    if (components.anotherAccountInfo.qValue != null) {\r\n        checkAccount = false;\r\n    }\r\n}\r\n\r\nif (check) {\r\n    if (components.type.qValue.value == 'ANOTHER_ACCOUNT') {\r\n        if (!checkAccount) {\r\n            components.anotherAccountInfo.errorMessages = 'Lütfen seçim yapınız.'\r\n        }\r\n        quick.EM.trace(\"1\")\r\n        quick.parent.events.searchClickEvent({feeAccountInfo:components.anotherAccountInfo.qValue, feePaymentType:components.type.qValue.value});\r\n    } else {\r\n        quick.EM.trace(\"2\")\r\n        quick.parent.events.searchClickEvent({feeAccountInfo:null, feePaymentType:components.type.qValue.value});\r\n    }\r\n    //quick.parent.events.searchClickEvent({feeAccountInfo:components.anotherAccountInfo.qValue.accountId, feePaymentType:components.type.qValue.value});\r\n    components.warnDialog.qValue = false;\r\n} else {\r\n    components.type.errorMessages = 'Lütfen seçim yapınız.'\r\n}",
