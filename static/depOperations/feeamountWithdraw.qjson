																											"C": {
																												"default": {
																													"c": [
																														{
																															"T": "VTextField",
																															"P": {
																																"ID": {
																																	"H": "totalAmount",
																																	"T": "prop",
																																	"HL": "QS"
																																},
																																"hideDetails": {
																																	"H": "false",
																																	"T": "prop"
																																},
																																"label": {
																																	"H": "'Toplam Ücret Tutarı'",
																																	"T": "prop",
																																	"HL": "QS"
																																},
																																"visible": {
																																	"H": "true",
																																	"T": "prop"
																																},
																																"readonly": {
																																	"H": "true",
																																	"T": "prop",
																																	"HL": "QS"
																																},
																																"formatValues": {
																																	"H": "{'alias'='decimal','groupSeparator'='.','radixPoint'=',','digits'=2,'enforceDigitOnBlur'=true}",
																																	"T": "attr",
																																	"HL": "QS"
																																},
																																"format": {
																																	"H": "'number'",
																																	"T": "attr",
																																	"HL": "QS"
																																}
																															},
																															"E": {
																																"input": {
																																	"H": "quick.EM.trace(\"change\")\r\n\r\nlet feeAmountResponse = quick.store.get(\"feeAmountResponse\");\r\n\r\nquick.EM.trace(value)\r\nquick.EM.trace(feeAmountResponse.feeAmount.unscaledValue)\r\nquick.EM.trace(feeAmountResponse.branchAuthorizedFeeAmount.unscaledValue)\r\n\r\nif (feeAmountResponse.customizationAllowed && (feeAmountResponse.feeAmount.unscaledValue == feeAmountResponse.branchAuthorizedFeeAmount.unscaledValue)) {\r\n    quick.EM.trace(\"first if\")\r\n    let maxFeeAmount = Number(feeAmountResponse.branchAuthorizedFeeAmount.unscaledValue) / Math.pow(10, 2);\r\n    quick.EM.trace(\"degerler\")\r\n    quick.EM.trace(value)\r\n    quick.EM.trace(maxFeeAmount)\r\n    if (value > maxFeeAmount) {\r\n        components.totalAmount.errorMessages = \"Belirlenen aralıktan fazla bir değer girdiniz\"\r\n    } else {\r\n        components.totalAmount.errorMessages = undefined\r\n        let totalAmount = quick.Quick.toDecimal(components.totalAmount.qValue, \",\");\r\n        let bsmv = Number(feeAmountResponse.bsmv.unscaledValue) / Math.pow(10, 5)\r\n\r\n        let taxAmount = totalAmount * bsmv;\r\n\r\n        const formattedResultTax = new Intl.NumberFormat(\"tr-TR\", {\r\n            minimumFractionDigits: 2,\r\n            maximumFractionDigits: 2\r\n            }).format(taxAmount);\r\n\r\n        components.taxAmount.qValue = formattedResultTax;\r\n        components.amount.qValue = totalAmount - taxAmount;\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n/*let scaledValue = Number(feeAmountResponse.feeAmount.unscaledValue) / Math.pow(10, 2);\r\nlet bsmv = Number(feeAmountResponse.bsmv.unscaledValue) / Math.pow(10, 5)\r\n\r\nlet taxAmount = scaledValue * bsmv;\r\n\r\nconst formattedResultTax = new Intl.NumberFormat(\"tr-TR\", {\r\n      minimumFractionDigits: 2,\r\n      maximumFractionDigits: 2\r\n    }).format(taxAmount);\r\n\r\ncomponents.taxAmount.qValue = formattedResultTax;\r\ncomponents.amount.qValue = amount;\r\n\r\n*/",
																																	"P": "value:any",
																																	"HL": "TS"
																																}
																															},
