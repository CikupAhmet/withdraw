		{
			"T": "Messaging",
			"P": {
				"ID": {
					"H": "PageCompWarn",
					"T": "prop",
					"HL": "QS"
				},
				"triggerOnRestored": {
					"H": "╬false╩╩",
					"T": "prop"
				},
				"externalEvents": {
					"H": "╬[]╠{}╠=╣name╩╠'searchClickEvent'╩╩╠=╣params╩╠[]╠'feeAccountInfo'╩╠'feePaymentType'╩╩╩╩╩╩",
					"T": "prop",
					"HL": "QS"
				}
			},
			"E": {
				"dialogClick": {
					"H": "Object.defineProperty(exports, \"__esModule\", { value: true });\r\n;\r\ncomponents.lblWarn.text = \"Ücret Bilgileri\";\r\ncomponents.warnDialog.qValue = true;\r\ncomponents.type.qValue = undefined;\r\nquick.MM.trigger('setAmount', [{ amount: amount, currency: currency, accountList: accountList, feeAmountResponse: feeAmountResponse }]);\r\n",
					"C": true,
					"EV": true,
					"HL": "JS"
				},
				"setAmount": {
					"H": "Object.defineProperty(exports, \"__esModule\", { value: true });\r\n;\r\nquick.EM.trace(\"setAmount\");\r\nquick.store.set(\"feeAmountResponse\", feeAmountResponse);\r\nquick.EM.trace(\"feeAmountDialogSet\");\r\nquick.EM.trace(accountList);\r\nif (feeAmountResponse.customizationAllowed) {\r\n    components.totalAmount.readonly = false;\r\n}\r\nvar scaledValue = Number(feeAmountResponse.feeAmount.unscaledValue) / Math.pow(10, 2);\r\nvar bsmv = Number(feeAmountResponse.bsmv.unscaledValue) / Math.pow(10, 5);\r\nvar taxAmount = scaledValue * bsmv;\r\nvar formattedResultTax = new Intl.NumberFormat(\"tr-TR\", {\r\n    minimumFractionDigits: 2,\r\n    maximumFractionDigits: 2\r\n}).format(taxAmount);\r\ncomponents.taxAmount.qValue = formattedResultTax;\r\ncomponents.amount.qValue = amount;\r\ncomponents.currency.qValue = currency;\r\ncomponents.anotherAccountInfo.items = accountList;\r\n",
					"C": true,
					"HL": "JS"
				}
			},
